# Server
PORT=3000

# CORS: origin фронтенда
FRONTEND_URL=http://localhost:5173

# Logging
NODE_ENV=development
LOG_LEVEL=debug

# JWT — сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_long_random_hex
JWT_REFRESH_SECRET=replace_me_with_another_long_random_hex
